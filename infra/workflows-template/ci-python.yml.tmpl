# Templated Python CI workflow.
# DO NOT COMMIT THE RENDERED .yml FORM FROM THIS PROCESS DIRECTLY.
# Use:
#   make ci-activate           # renders __GHA_OPEN__/__GHA_CLOSE__ → $ ... 
# or:
#   bash scripts/install-workflows.sh
#
# Why sentinels: the AI agent's GitHub MCP integration cannot push files to
# .github/workflows/* (App scope), and its tool-call serializer strips
# consecutive double-braces. Sentinels survive both.

name: ci-python

on:
  push:
    branches: [main, "feat/**"]
  pull_request:
    branches: [main]

concurrency:
  group: ci-python-__GHA_OPEN__ github.ref __GHA_CLOSE__
  cancel-in-progress: true

jobs:
  python:
    name: "py / __GHA_OPEN__ matrix.target __GHA_CLOSE__"
    runs-on: ubuntu-latest
    strategy:
      fail-fast: false
      matrix:
        target:
          - packages/schemas
          - packages/graph
          - apps/api
    steps:
      - uses: actions/checkout@v4

      - name: Set up uv
        uses: astral-sh/setup-uv@v3
        with:
          enable-cache: true

      - name: Set up Python
        run: uv python install 3.11

      - name: Install workspace deps
        run: uv sync --all-packages --dev

      - name: Ruff check
        run: uv run ruff check __GHA_OPEN__ matrix.target __GHA_CLOSE__

      - name: Pyright (basic)
        run: uv run pyright __GHA_OPEN__ matrix.target __GHA_CLOSE__

      - name: Pytest with coverage
        run: |
          if [ -d "__GHA_OPEN__ matrix.target __GHA_CLOSE__/tests" ]; then
            uv run --directory __GHA_OPEN__ matrix.target __GHA_CLOSE__ \
              pytest -ra --cov --cov-report=xml --cov-report=term-missing
          else
            echo "no tests in __GHA_OPEN__ matrix.target __GHA_CLOSE__; skipping pytest"
          fi

      - name: Upload coverage
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: coverage-__GHA_OPEN__ replace(matrix.target, '/', '-') __GHA_CLOSE__
          path: __GHA_OPEN__ matrix.target __GHA_CLOSE__/coverage.xml
          if-no-files-found: ignore
