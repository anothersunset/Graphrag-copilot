# LLM
LLM_MODEL=glm-4-flash
LLM_API_KEY=
LLM_BASE_URL=
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096

# Zhipu (recommended free-tier)
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# Embedding
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DIMENSION=512
EMBEDDING_DEVICE=cpu

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=graphrag123

# Retrieval
VECTOR_SEARCH_TOP_K=10
BM25_TOP_K=10
GRAPH_SEARCH_DEPTH=2
VECTOR_WEIGHT=0.55
BM25_WEIGHT=0.25
GRAPH_WEIGHT=0.20
VERIFICATION_THRESHOLD=0.8

# Security (P0)
# 生产环境请设为 true 并填入 API_KEYS（逗号分隔，仅接受服务端中包含的 key）
# 请勿提交真实 key 到仓库；.env 已加入 .gitignore
ENABLE_AUTH=false
API_KEYS=replace-me-with-comma-separated-keys
RATE_LIMIT_PER_MIN=60

# Logging (P0)
# loguru 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
